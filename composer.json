{
    "name": "devel/devel",
    "description": "PHP web application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "doctrine/dbal": "^4.0",
        "doctrine/migrations": "^3.6",
        "doctrine/orm": "^3.0",
        "firebase/php-jwt": "^7.0",
        "nikic/fast-route": "^1.3",
        "nyholm/psr7": "^1.8",
        "openai-php/client": "0.8",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0",
        "ramsey/uuid": "^4.7",
        "symfony/cache": "^7.0",
        "symfony/console": "^7.0",
        "symfony/http-client": "^7.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "php-http/discovery": true
        }
    }
}
